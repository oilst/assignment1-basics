{
  "seed": 42,
  "train_dataset": "data/TS-train-tokens.npy",
  "val_dataset": "data/TS-valid-tokens.npy",
  "output_dir": "./logs",
  "device": "auto",
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 1344,
    "rope_theta": 10000.0
  },
  "optimizer": {
    "lr": 0.001,
    "weight_decay": 0.01,
    "beta1": 0.9,
    "beta2": 0.999,
    "eps": 1e-8
  },
  "training": {
    "batch_size": 256,
    "gradient_accumulation_steps": 1,
    "num_iterations": 700,
    "warmup_iters": 0,
    "log_every": 100,
    "performance_log_every": 100,
    "eval_iters": 10,
    "checkpoint_every": 1000,
    "gradient_clip": 1.0
  }
}
